# ONX Intelligence - Founder Alpha Deployment
# Copy to .env and fill with real values

# Database
DATABASE_URL=mysql://user:password@localhost:3306/onx_intelligence

# Authentication
VITE_KIMI_AUTH_URL=https://portal.kimi.com/oauth
VITE_APP_ID=your-app-id
APP_SECRET=your-app-secret

# Model Gateway
DEFAULT_PROVIDER=openai
OPENAI_API_KEY=sk-your-key
QWEN_API_KEY=your-qwen-key
DEEPSEEK_API_KEY=your-deepseek-key

# Tool Gateway
RUNWAY_API_KEY=your-runway-key
SEARCH_API_KEY=your-search-key
KNOWLEDGE_API_KEY=your-knowledge-key

# Founder Identity
FOUNDER_ID=founder-001
INSTITUTIONS=EliteVet,Pawz,VetsVan
